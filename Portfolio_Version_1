/* ===================== BLOG RENDERER ===================== */
function renderBlogGrid() {
  var grid = document.getElementById('blog-grid');
  BLOG_POSTS.forEach(function(post) {
    var card = document.createElement('div');
    card.className = 'blog-card fade-in';
    card.onclick = function() { openBlogPost(post.id); };
    card.innerHTML = `
      <div class="blog-thumb">
        <img src="${post.thumb}" alt="${post.title}" onerror="this.style.display='none'" />
        <div class="blog-thumb-fallback" style="display:${post.thumb ? 'none' : 'flex'}">&#128221;</div>
        <div class="blog-thumb-overlay"></div>
        <div class="blog-cat">${post.category}</div>
      </div>
      <div class="blog-body">
        <div class="blog-date">${post.date}</div>
        <div class="blog-title">${post.title}</div>
        <div class="blog-excerpt">${post.excerpt}</div>
        <div class="blog-footer">
          <div class="blog-read">Read Post &rarr;</div>
          <div class="blog-read-time">${post.readTime}</div>
        </div>
      </div>
    `;
    grid.appendChild(card);
  });
}

function openBlogPost(id) {
  var post = BLOG_POSTS.find(function(p) { return p.id === id; });
  if (!post) return;
  document.getElementById('blog-index-view').style.display = 'none';
  var postView = document.getElementById('blog-post-view');
  postView.style.display = 'block';
  document.getElementById('post-content-container').innerHTML = post.content;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function closeBlogPost() {
  document.getElementById('blog-post-view').style.display = 'none';
  document.getElementById('blog-index-view').style.display = 'block';
  window.scrollTo({ top: 0, behavior: 'smooth' });
  setTimeout(initFadeIns, 80);
}

/* ===================== PAGE ROUTING ===================== */
function showPage(id) {
  document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });
  document.getElementById('page-' + id).classList.add('active');
  document.querySelectorAll('.nav-links a[data-page]').forEach(function(a) {
    a.classList.toggle('active', a.dataset.page === id);
  });
  if (id === 'blog') {
    document.getElementById('blog-index-view').style.display = 'block';
    document.getElementById('blog-post-view').style.display = 'none';
  }
  window.scrollTo({ top: 0, behavior: 'smooth' });
  setTimeout(initFadeIns, 80);
}

/* ===================== FADE INS ===================== */
function initFadeIns() {
  var els = document.querySelectorAll('.page.active .fade-in');
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.07 });
  els.forEach(function(el) { el.classList.remove('visible'); obs.observe(el); });
}

/* ===================== PARALLAX ===================== */

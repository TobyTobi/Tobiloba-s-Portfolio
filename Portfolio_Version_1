<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tobiloba Babajide — Data/BI Analyst</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#080c10; --surface:#0d1318; --surface2:#111920;
    --border:rgba(255,255,255,0.06); --accent:#00e5ff;
    --accent2:#7c3aed; --accent3:#f59e0b;
    --text:#e8edf2; --muted:#64748b; --muted2:#94a3b8;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--text);font-family:'Outfit',sans-serif;font-weight:300;overflow-x:hidden}
  body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,229,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(0,229,255,.03) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;z-index:0}
  .orb{position:fixed;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(0,229,255,.07) 0%,transparent 70%);pointer-events:none;z-index:0;top:-100px;right:-100px;animation:pulse 8s ease-in-out infinite}
  .orb2{position:fixed;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(124,58,237,.05) 0%,transparent 70%);pointer-events:none;z-index:0;bottom:-100px;left:-100px;animation:pulse 10s ease-in-out infinite reverse}
  @keyframes pulse{0%,100%{transform:scale(1);opacity:.8}50%{transform:scale(1.1);opacity:1}}

  /* NAV */
  nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:20px 60px;display:flex;justify-content:space-between;align-items:center;background:rgba(8,12,16,.88);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
  .nav-logo{font-family:'DM Mono',monospace;font-size:13px;font-weight:500;color:var(--accent);letter-spacing:.15em;text-transform:uppercase;cursor:pointer}
  .nav-links{display:flex;gap:32px;list-style:none}
  .nav-links a{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted2);text-decoration:none;transition:color .2s;position:relative;cursor:pointer}
  .nav-links a::after{content:'';position:absolute;bottom:-3px;left:0;width:0;height:1px;background:var(--accent);transition:width .3s}
  .nav-links a:hover,.nav-links a.active{color:var(--accent)}
  .nav-links a:hover::after,.nav-links a.active::after{width:100%}

  /* PAGES */
  .page{display:none;min-height:100vh;position:relative;z-index:1}
  .page.active{display:block}

  /* SHARED */
  .section-tag{font-family:'DM Mono',monospace;font-size:11px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:20px;display:flex;align-items:center;gap:12px}
  .section-tag::before{content:'';display:inline-block;width:24px;height:1px;background:var(--accent)}
  h2{font-family:'DM Serif Display',serif;font-size:clamp(36px,5vw,64px);font-weight:400;line-height:1.05;margin-bottom:64px;letter-spacing:-.02em}

  /* HOME */
  #hero{min-height:100vh;display:grid;grid-template-columns:1fr auto;gap:0;align-items:center;padding:120px 60px 80px}
  .hero-content{display:flex;flex-direction:column;justify-content:center}
  .hero-photo-col{display:flex;align-items:center;justify-content:flex-end;padding-left:60px}
  .hero-photo-frame{position:relative;width:360px;flex-shrink:0}
  .hero-photo-frame::before{content:'';position:absolute;top:-14px;right:-14px;bottom:14px;left:14px;border:1px solid rgba(0,229,255,0.22);z-index:0;pointer-events:none}
  .hero-photo-frame::after{content:'';position:absolute;top:14px;right:14px;bottom:-14px;left:-14px;border:1px solid rgba(124,58,237,0.18);z-index:0;pointer-events:none}
  .hero-photo-inner{position:relative;z-index:1;overflow:hidden;clip-path:polygon(0 0,calc(100% - 20px) 0,100% 20px,100% 100%,20px 100%,0 calc(100% - 20px))}
  .hero-photo-inner img{width:100%;height:480px;object-fit:cover;object-position:center top;display:block;filter:grayscale(15%) contrast(1.05);transition:filter 0.4s ease,transform 0.4s ease}
  .hero-photo-inner:hover img{filter:grayscale(0%) contrast(1.08);transform:scale(1.02)}
  .hero-photo-glow{position:absolute;bottom:-40px;left:50%;transform:translateX(-50%);width:220px;height:70px;background:radial-gradient(ellipse,rgba(0,229,255,0.15) 0%,transparent 70%);z-index:0;pointer-events:none}
  .hero-photo-label{position:absolute;bottom:0;left:0;right:0;text-align:center;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(0,229,255,0.8);z-index:2;background:linear-gradient(transparent,rgba(8,12,16,0.92) 55%);padding:36px 12px 14px}
  .hero-accent-line{position:absolute;top:0;left:0;width:3px;height:100%;background:linear-gradient(180deg,var(--accent),var(--accent2) 60%,transparent);z-index:2}
  .hero-corner-dot{position:absolute;width:6px;height:6px;background:var(--accent);z-index:3}
  .hero-corner-dot.tl{top:-14px;left:14px}
  .hero-corner-dot.br{bottom:-14px;right:14px}
  .hero-tag{font-family:'DM Mono',monospace;font-size:11px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:28px;display:flex;align-items:center;gap:12px}
  .hero-tag::before{content:'';display:inline-block;width:32px;height:1px;background:var(--accent)}
  h1{font-family:'DM Serif Display',serif;font-size:clamp(52px,8vw,110px);line-height:.92;font-weight:400;letter-spacing:-.02em;margin-bottom:32px;max-width:900px}
  h1 em{font-style:italic;color:var(--accent)}
  .hero-desc{font-size:18px;font-weight:300;line-height:1.7;color:var(--muted2);max-width:540px;margin-bottom:52px}
  .hero-cta{display:flex;gap:16px;flex-wrap:wrap}
  .btn-primary{display:inline-flex;align-items:center;gap:10px;padding:14px 32px;background:var(--accent);color:var(--bg);font-family:'DM Mono',monospace;font-size:12px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;transition:all .25s;border:none;clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,10px 100%,0 calc(100% - 10px))}
  .btn-primary:hover{background:#33eaff;transform:translateY(-2px);box-shadow:0 12px 40px rgba(0,229,255,.3)}
  .btn-secondary{display:inline-flex;align-items:center;gap:10px;padding:14px 32px;border:1px solid rgba(0,229,255,.3);color:var(--accent);font-family:'DM Mono',monospace;font-size:12px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;transition:all .25s;background:transparent;clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,10px 100%,0 calc(100% - 10px))}
  .btn-secondary:hover{background:rgba(0,229,255,.07);transform:translateY(-2px)}
  .hero-stats{display:flex;gap:20px;flex-wrap:wrap;margin-top:60px}
  .stat-card{background:var(--surface);border:1px solid var(--border);padding:20px 28px;min-width:200px;position:relative;overflow:hidden}
  .stat-card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--accent)}
  .stat-card:nth-child(2)::before{background:var(--accent2)}
  .stat-card:nth-child(3)::before{background:var(--accent3)}
  .stat-number{font-family:'DM Serif Display',serif;font-size:36px;line-height:1;margin-bottom:4px}
  .stat-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}

  #awards{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:100px 60px}
  .awards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2px}
  .award-item{background:var(--bg);padding:40px 36px;border:1px solid var(--border);transition:all .3s;position:relative;overflow:hidden}
  .award-item::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));transform:scaleX(0);transition:transform .4s}
  .award-item:hover{background:var(--surface2);transform:translateY(-4px)}
  .award-item:hover::after{transform:scaleX(1)}
  .award-icon{font-size:28px;margin-bottom:16px;display:block}
  .award-title{font-family:'DM Serif Display',serif;font-size:20px;margin-bottom:10px;font-weight:400}
  .award-desc{font-size:14px;color:var(--muted2);line-height:1.6}

  #experience{padding:100px 60px}
  .exp-list{display:flex;flex-direction:column}
  .exp-item{display:grid;grid-template-columns:220px 1fr;gap:40px;padding:40px 0;border-bottom:1px solid var(--border);transition:all .3s}
  .exp-item:first-child{border-top:1px solid var(--border)}
  .exp-item:hover .exp-title{color:var(--accent)}
  .exp-meta{display:flex;flex-direction:column;gap:6px;padding-top:4px}
  .exp-company{font-family:'DM Mono',monospace;font-size:12px;font-weight:500;letter-spacing:.08em;color:var(--accent);text-transform:uppercase}
  .exp-date{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted)}
  .exp-title{font-family:'DM Serif Display',serif;font-size:26px;font-weight:400;margin-bottom:16px;transition:color .3s}
  .exp-desc{font-size:15px;color:var(--muted2);line-height:1.75;max-width:680px}

  #skills{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:100px 60px}
  .skills-layout{display:grid;grid-template-columns:1fr 1fr;gap:60px}
  .skills-group h3{font-family:'DM Mono',monospace;font-size:11px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:28px}
  .skill-tags{display:flex;flex-wrap:wrap;gap:10px}
  .skill-tag{padding:8px 16px;border:1px solid var(--border);font-family:'DM Mono',monospace;font-size:12px;color:var(--text);letter-spacing:.05em;transition:all .25s;background:var(--bg)}
  .skill-tag:hover{border-color:rgba(0,229,255,.4);color:var(--accent)}
  .skill-tag.featured{border-color:rgba(0,229,255,.3);color:var(--accent);background:rgba(0,229,255,.05)}

  #education{padding:100px 60px}
  .edu-certs-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start}
  .edu-block h3,.cert-block h3{font-family:'DM Mono',monospace;font-size:11px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:32px}
  .edu-items,.cert-items{display:flex;flex-direction:column;gap:16px}
  .edu-item,.cert-item{padding:24px 28px;border:1px solid var(--border);background:var(--surface);transition:all .3s}
  .edu-item:hover,.cert-item:hover{border-color:rgba(0,229,255,.2);background:var(--surface2)}
  .edu-degree{font-family:'DM Serif Display',serif;font-size:20px;font-weight:400;margin-bottom:6px}
  .edu-school,.cert-issuer{font-family:'DM Mono',monospace;font-size:11px;color:var(--accent);letter-spacing:.1em;text-transform:uppercase}
  .cert-name{font-size:15px;font-weight:500;margin-bottom:6px;color:var(--text)}
  .cert-item a{color:inherit;text-decoration:none}
  .cert-item a:hover .cert-name{color:var(--accent)}

  #contact{background:var(--surface);border-top:1px solid var(--border);text-align:center;padding:100px 60px}
  .contact-sub{font-size:18px;color:var(--muted2);margin-bottom:52px;max-width:500px;margin-left:auto;margin-right:auto;line-height:1.6}
  .contact-links{display:flex;justify-content:center;flex-wrap:wrap;gap:16px}
  .contact-link{display:inline-flex;align-items:center;gap:8px;padding:12px 24px;border:1px solid var(--border);color:var(--muted2);text-decoration:none;font-family:'DM Mono',monospace;font-size:12px;letter-spacing:.1em;text-transform:uppercase;transition:all .25s;background:var(--bg)}
  .contact-link:hover{border-color:var(--accent);color:var(--accent);background:rgba(0,229,255,.05);transform:translateY(-2px)}

  /* PROJECTS */
  .page-hero{padding:160px 60px 80px;border-bottom:1px solid var(--border)}
  .projects-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:2px;padding:60px}
  .project-card{background:var(--surface);border:1px solid var(--border);padding:40px 36px;transition:all .3s;position:relative;overflow:hidden;text-decoration:none;color:inherit;display:block}
  .project-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));transform:scaleX(0);transform-origin:left;transition:transform .4s}
  .project-card:hover{background:var(--surface2);transform:translateY(-4px)}
  .project-card:hover::before{transform:scaleX(1)}
  .project-tools{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px}
  .tool-badge{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.1em;text-transform:uppercase;padding:4px 10px;border:1px solid rgba(0,229,255,.2);color:var(--accent);background:rgba(0,229,255,.04)}
  .project-title{font-family:'DM Serif Display',serif;font-size:24px;font-weight:400;margin-bottom:14px;line-height:1.2;transition:color .3s}
  .project-card:hover .project-title{color:var(--accent)}
  .project-desc{font-size:14px;color:var(--muted2);line-height:1.7;padding-bottom:28px}
  .project-arrow{position:absolute;bottom:28px;right:32px;font-size:18px;color:var(--muted);transition:all .3s}
  .project-card:hover .project-arrow{color:var(--accent);transform:translate(3px,-3px)}

  /* VISUALIZATIONS */
  .viz-section{padding:60px 60px 0}
  .viz-section-header{font-family:'DM Mono',monospace;font-size:11px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:32px;display:flex;align-items:center;gap:16px}
  .viz-section-header::after{content:'';flex:1;height:1px;background:var(--border)}
  .viz-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:2px}
  .viz-card{background:var(--surface);border:1px solid var(--border);transition:all .3s;position:relative;overflow:hidden;text-decoration:none;color:inherit;display:block}
  .viz-card:hover{border-color:rgba(0,229,255,.25);transform:translateY(-3px);box-shadow:0 12px 40px rgba(0,0,0,.4)}
  .viz-thumb{width:100%;aspect-ratio:16/9;background:var(--surface2);overflow:hidden;position:relative}
  .viz-thumb img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s ease}
  .viz-card:hover .viz-thumb img{transform:scale(1.04)}
  .viz-thumb-fallback{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0d1318,#111920);font-size:32px;opacity:.5;position:absolute;top:0;left:0}
  .viz-badge{position:absolute;top:10px;right:10px;font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.12em;text-transform:uppercase;padding:4px 10px;background:rgba(219,123,45,0.89);border:1px solid rgba(255,255,255,0.15);color:#e5e7eb;backdrop-filter:blur(6px);z-index:2}
  .viz-info{padding:20px 24px}
  .viz-name{font-size:14px;font-weight:500;margin-bottom:6px;line-height:1.4;transition:color .3s}
  .viz-card:hover .viz-name{color:var(--accent)}
  .viz-meta{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}

  /* ===================== BLOG STYLES ===================== */
  .blog-index{padding:60px}
  .blog-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:28px}
  .blog-card{background:var(--surface);border:1px solid var(--border);overflow:hidden;cursor:pointer;transition:all .35s;position:relative;display:flex;flex-direction:column}
  .blog-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));transform:scaleX(0);transform-origin:left;transition:transform .4s;z-index:1}
  .blog-card:hover{transform:translateY(-5px);border-color:rgba(0,229,255,.2);box-shadow:0 20px 60px rgba(0,0,0,.5)}
  .blog-card:hover::before{transform:scaleX(1)}
  .blog-thumb{width:100%;height:200px;overflow:hidden;position:relative;background:var(--surface2)}
  .blog-thumb img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
  .blog-card:hover .blog-thumb img{transform:scale(1.06)}
  .blog-thumb-fallback{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0d1318 0%,#111920 50%,#0d1a24 100%);font-size:48px}
  .blog-thumb-overlay{position:absolute;inset:0;background:linear-gradient(transparent 40%,rgba(8,12,16,.8));pointer-events:none}
  .blog-cat{position:absolute;top:14px;left:14px;font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.15em;text-transform:uppercase;padding:5px 12px;background:rgba(0,229,255,.12);border:1px solid rgba(0,229,255,.3);color:var(--accent);backdrop-filter:blur(8px)}
  .blog-body{padding:28px 28px 24px;flex:1;display:flex;flex-direction:column}
  .blog-date{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:12px}
  .blog-title{font-family:'DM Serif Display',serif;font-size:22px;font-weight:400;line-height:1.25;margin-bottom:12px;color:var(--text);transition:color .3s}
  .blog-card:hover .blog-title{color:var(--accent)}
  .blog-excerpt{font-size:14px;color:var(--muted2);line-height:1.7;flex:1;margin-bottom:20px}
  .blog-footer{display:flex;align-items:center;justify-content:space-between;padding-top:16px;border-top:1px solid var(--border)}
  .blog-read{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);display:flex;align-items:center;gap:6px}
  .blog-read-time{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:.08em}

  /* BLOG POST (reader) */
  #blog-post-view{display:none;padding:140px 0 80px}
  #blog-post-view.active{display:block}
  .post-back{display:inline-flex;align-items:center;gap:10px;font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted2);cursor:pointer;transition:color .2s;margin:0 60px 48px;padding:10px 0}
  .post-back:hover{color:var(--accent)}
  .post-back::before{content:'←';font-size:14px}
  .post-container{max-width:780px;margin:0 auto;padding:0 60px}
  .post-cat-badge{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);display:inline-flex;align-items:center;gap:10px;margin-bottom:24px}
  .post-cat-badge::before{content:'';display:inline-block;width:20px;height:1px;background:var(--accent)}
  .post-title{font-family:'DM Serif Display',serif;font-size:clamp(36px,5vw,60px);font-weight:400;line-height:1.05;letter-spacing:-.02em;margin-bottom:24px}
  .post-meta-row{display:flex;align-items:center;gap:20px;margin-bottom:48px;padding-bottom:28px;border-bottom:1px solid var(--border)}
  .post-author{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted2);letter-spacing:.08em}
  .post-date{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);letter-spacing:.08em}
  .post-sep{width:3px;height:3px;background:var(--muted);border-radius:50%}
  .post-read-time{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);letter-spacing:.08em}
  .post-hero-img{width:100%;height:340px;object-fit:cover;margin-bottom:52px;border:1px solid var(--border)}
  .post-body{font-size:17px;line-height:1.85;color:var(--muted2)}
  .post-body p{margin-bottom:24px}
  .post-body h3{font-family:'DM Serif Display',serif;font-size:26px;font-weight:400;color:var(--text);margin:48px 0 18px;letter-spacing:-.01em}
  .post-body h3::before{content:'// ';color:var(--accent);font-family:'DM Mono',monospace;font-size:14px;vertical-align:middle}
  .post-body strong{color:var(--text);font-weight:500}
  .post-body a{color:var(--accent);text-decoration:none;border-bottom:1px solid rgba(0,229,255,.3);transition:border-color .2s}
  .post-body a:hover{border-color:var(--accent)}
  .post-body .post-img{width:100%;margin:32px 0;border:1px solid var(--border);display:block}
  .post-body .code-block{background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--accent);padding:20px 24px;font-family:'DM Mono',monospace;font-size:13px;color:var(--accent);margin:28px 0;line-height:1.6;overflow-x:auto}
  .post-body .highlight-box{background:var(--surface2);border:1px solid var(--border);border-left:3px solid var(--accent2);padding:20px 24px;margin:28px 0;font-size:15px;color:var(--muted2)}
  .post-end{margin-top:64px;padding-top:40px;border-top:1px solid var(--border);text-align:center}
  .post-end p{font-family:'DM Mono',monospace;font-size:12px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase}

  /* FOOTER */
  footer{padding:28px 60px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--border);z-index:1;position:relative}
  .footer-copy,.footer-role{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);letter-spacing:.1em}

  /* ANIMATIONS */
  .fade-in{opacity:0;transform:translateY(24px);transition:opacity .7s ease,transform .7s ease}
  .fade-in.visible{opacity:1;transform:translateY(0)}

  /* RESPONSIVE */

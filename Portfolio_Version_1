function buildVizCard(item, type) {
  var url = 'https://public.tableau.com/app/profile/tobiloba.babajide/viz/' + item.wb + '/' + item.sheet;
  var thumb = 'https://public.tableau.com/thumb/views/' + item.wb + '/' + item.sheet;
  var metaLabel = type === 'dashboard'
    ? ('Dashboard' + (item.votd ? ' &middot; #VizoftheDay' : ''))
    : ('Data Story' + (item.meta ? ' &middot; ' + item.meta : ''));
  var a = document.createElement('a');
  a.href = url; a.target = '_blank'; a.className = 'viz-card fade-in';
  var thumbDiv = document.createElement('div'); thumbDiv.className = 'viz-thumb';
  var fallback = document.createElement('div'); fallback.className = 'viz-thumb-fallback'; fallback.textContent = '\uD83D\uDCCA';
  thumbDiv.appendChild(fallback);
  var img = document.createElement('img'); img.alt = item.title; img.loading = 'lazy';
  img.style.position = 'relative'; img.style.zIndex = '1'; img.src = thumb;
  img.onerror = function() { this.style.display = 'none'; };
  thumbDiv.appendChild(img);
  if (item.votd) { var badge = document.createElement('div'); badge.className = 'viz-badge'; badge.textContent = 'Viz of the Day'; thumbDiv.appendChild(badge); }
  var info = document.createElement('div'); info.className = 'viz-info';
  info.innerHTML = '<div class="viz-name">' + item.title + '</div><div class="viz-meta">' + metaLabel + '</div>';
  a.appendChild(thumbDiv); a.appendChild(info);
  return a;
}

